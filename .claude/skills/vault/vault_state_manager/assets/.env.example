# Vault State Manager Configuration
# Copy this file to .env and fill in actual values

# REQUIRED: Absolute path to Obsidian vault root
VAULT_PATH="/absolute/path/to/vault"

# Example for local development:
# VAULT_PATH="/Users/john/Documents/obsidian-vault"

# Example for Docker container:
# VAULT_PATH="/vault"

# Example for Windows:
# VAULT_PATH="C:\Users\John\Documents\obsidian-vault"

# OPTIONAL: Operation timeouts (milliseconds)
VAULT_CLAIM_TIMEOUT_MS=5000    # File lock claim timeout
VAULT_READ_TIMEOUT_MS=3000     # Read operation timeout
VAULT_WRITE_TIMEOUT_MS=5000    # Write operation timeout
VAULT_MOVE_TIMEOUT_MS=3000     # Move operation timeout

# OPTIONAL: Logging configuration
VAULT_LOG_LEVEL="info"         # debug | info | warn | error
VAULT_LOG_FORMAT="json"        # json | text

# OPTIONAL: Performance tuning
VAULT_POLL_INTERVAL_MS=5000    # How often to poll for new files
VAULT_MAX_RETRIES=3            # Max retries for transient errors
VAULT_RETRY_BACKOFF_MS=1000    # Exponential backoff base (ms)

# OPTIONAL: Log rotation
VAULT_LOG_MAX_SIZE_MB=100      # Rotate logs when exceeding size
VAULT_LOG_MAX_AGE_DAYS=30      # Delete logs older than this

# OPTIONAL: Archive policy
VAULT_ARCHIVE_AGE_DAYS=30      # Move Done plans to Archive after N days

# IMPORTANT: Never commit this file with real paths!
# Add .env to .gitignore
