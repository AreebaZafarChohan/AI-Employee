# Task Lifecycle Manager Configuration

# Claim behavior
TASK_CLAIM_TIMEOUT_MS=5000           # Timeout for claiming tasks
TASK_CONFLICT_STRATEGY="skip"        # skip | retry | fail

# Retry configuration
TASK_MAX_RETRIES=3                   # Maximum retry attempts for failed tasks
TASK_RETRY_BACKOFF_MS=1000           # Exponential backoff base (ms)

# Recovery thresholds
TASK_STALE_THRESHOLD_MINUTES=60      # Recover tasks stuck in Plans/ > this time
TASK_ORPHAN_THRESHOLD_MINUTES=30     # Recover tasks stuck in In_Progress/ > this time
TASK_PENDING_ALERT_HOURS=4           # Alert if task in Pending_Approval/ > this time

# Workflow policies
TASK_AUTO_APPROVE_SAFE_ACTIONS="false"  # Auto-approve low-risk tasks (Gold/Platinum tier)
TASK_PARALLEL_LIMIT=1                   # Max parallel tasks per agent (Bronze=1, Gold=3)
TASK_REQUIRE_HEARTBEAT="true"           # Require agents to send heartbeat while processing

# Recovery jobs
TASK_RECOVERY_INTERVAL_MS=300000     # Run recovery jobs every 5 minutes
TASK_HEALTH_CHECK_INTERVAL_MS=600000 # Run full health check every 10 minutes

# Logging
TASK_LOG_TRANSITIONS="true"          # Log all state transitions
TASK_LOG_CONFLICTS="true"            # Log claim conflicts
TASK_LOG_RECOVERY="true"             # Log recovery actions
TASK_SANITIZE_LOGS="true"            # Remove sensitive data from logs

# Performance
TASK_LIST_CACHE_MS=5000              # Cache task list for 5 seconds
TASK_BATCH_SIZE=10                   # Process max N tasks per iteration

# IMPORTANT: Never commit real values
# Add .env to .gitignore
