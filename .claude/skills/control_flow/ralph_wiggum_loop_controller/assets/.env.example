# Ralph Wiggum Loop Controller - Environment Variables

# ============================================================================
# REQUIRED: Vault and Directories
# ============================================================================

# Vault root directory (absolute path)
VAULT_PATH="/absolute/path/to/vault"

# Loops directory (relative to VAULT_PATH or absolute)
LOOPS_DIR="${VAULT_PATH}/Loops"

# Signals directory (relative to VAULT_PATH or absolute)
SIGNALS_DIR="${VAULT_PATH}/Signals"

# ============================================================================
# Loop Configuration
# ============================================================================

# Check interval for stop hooks (milliseconds)
# How often to check if loop should continue
# Recommended: 5000 (5 seconds)
LOOP_CHECK_INTERVAL_MS=5000

# Default timeout for loops (milliseconds)
# Used if no timeout hook specified
# Recommended: 600000 (10 minutes)
LOOP_TIMEOUT_DEFAULT_MS=600000

# Maximum iterations per loop
# Safety limit to prevent infinite loops
# Recommended: 100
MAX_LOOP_ITERATIONS=100

# Maximum concurrent loops
# Limit to prevent resource exhaustion
# Recommended: 10
MAX_CONCURRENT_LOOPS=10

# Maximum loops per agent
# Prevent single agent from monopolizing resources
# Recommended: 3
MAX_LOOPS_PER_AGENT=3

# ============================================================================
# Prompt Injection
# ============================================================================

# Default signal expiry time (milliseconds)
# How long before injected prompt expires
# Recommended: 300000 (5 minutes)
SIGNAL_EXPIRY_MS=300000

# Prompt injection rate limit (per minute)
# Prevent overwhelming target agent
# Recommended: 10
PROMPT_INJECTION_RATE_LIMIT=10

# Maximum prompt length (characters)
# Prevent oversized prompts
# Recommended: 10000
MAX_PROMPT_LENGTH=10000

# ============================================================================
# Retry & Backoff
# ============================================================================

# Maximum retry attempts
# Default if not specified in hook
# Recommended: 5
MAX_RETRY_ATTEMPTS=5

# Maximum backoff delay (milliseconds)
# Cap exponential backoff
# Recommended: 60000 (1 minute)
MAX_BACKOFF_DELAY_MS=60000

# Enable backoff jitter (true/false)
# Add randomness to backoff to prevent thundering herd
# Recommended: true
BACKOFF_JITTER_ENABLED=true

# Backoff jitter percentage (0.0 - 1.0)
# Recommended: 0.2 (20%)
BACKOFF_JITTER_PERCENT=0.2

# ============================================================================
# Circuit Breaker
# ============================================================================

# Enable circuit breaker (true/false)
# Automatically stop failing loops
# Recommended: true for production
CIRCUIT_BREAKER_ENABLED=true

# Circuit breaker failure threshold
# Number of failures before opening circuit
# Recommended: 5
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker reset timeout (milliseconds)
# How long before resetting circuit
# Recommended: 60000 (1 minute)
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# ============================================================================
# Resource Limits
# ============================================================================

# Default memory limit per loop (MB)
# Recommended: 512
DEFAULT_MEMORY_LIMIT_MB=512

# Default CPU limit per loop (percent)
# Recommended: 80
DEFAULT_CPU_LIMIT_PERCENT=80

# Global memory limit for all loops (MB)
# Recommended: 2048
GLOBAL_MEMORY_LIMIT_MB=2048

# ============================================================================
# Checkpoints
# ============================================================================

# Enable checkpoint recovery (true/false)
# Recommended: true for long-running loops
CHECKPOINT_ENABLED=true

# Checkpoint interval (iterations)
# Create checkpoint every N iterations
# Recommended: 10
CHECKPOINT_INTERVAL_ITERATIONS=10

# Maximum checkpoints to keep per loop
# Recommended: 3 (keep last 3)
MAX_CHECKPOINTS_PER_LOOP=3

# ============================================================================
# Cleanup & Maintenance
# ============================================================================

# Orphaned signal cleanup interval (milliseconds)
# How often to clean up expired signals
# Recommended: 3600000 (1 hour)
SIGNAL_CLEANUP_INTERVAL_MS=3600000

# Zombie loop check interval (milliseconds)
# How often to check for crashed loops
# Recommended: 60000 (1 minute)
ZOMBIE_CHECK_INTERVAL_MS=60000

# Loop heartbeat timeout (milliseconds)
# How long without heartbeat before considering loop dead
# Recommended: 60000 (1 minute)
LOOP_HEARTBEAT_TIMEOUT_MS=60000

# Archive retention days
# Delete archived loops older than N days
# Recommended: 30
ARCHIVE_RETENTION_DAYS=30

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Enable audit logging (true/false)
# Recommended: true
AUDIT_LOG_ENABLED=true

# Enable metrics collection (true/false)
# Recommended: true
METRICS_ENABLED=true

# Metrics export interval (milliseconds)
# Recommended: 60000 (1 minute)
METRICS_EXPORT_INTERVAL_MS=60000

# Log level (debug, info, warn, error)
# Recommended: info for production, debug for development
LOG_LEVEL=info

# ============================================================================
# Security
# ============================================================================

# Enable prompt variable sanitization (true/false)
# Recommended: true
SANITIZE_VARIABLES=true

# Enable script path validation (true/false)
# Prevent path traversal attacks
# Recommended: true
VALIDATE_SCRIPT_PATHS=true

# Allowed script directories (comma-separated)
# Only allow custom scripts from these directories
ALLOWED_SCRIPT_DIRS="${VAULT_PATH}/.specify/scripts,${VAULT_PATH}/scripts"

# File permissions for loop task files (octal)
# Recommended: 0600 (owner only) or 0644 (owner write, all read)
LOOP_FILE_PERMISSIONS=0644

# Signal file permissions (octal)
# Recommended: 0644
SIGNAL_FILE_PERMISSIONS=0644

# ============================================================================
# Integration
# ============================================================================

# Enable agent_delegation_manager integration (true/false)
DELEGATION_INTEGRATION_ENABLED=false

# Enable agent_claim_coordinator integration (true/false)
CLAIM_INTEGRATION_ENABLED=false

# Enable audit_log_writer integration (true/false)
AUDIT_INTEGRATION_ENABLED=true
