# Time Event Scheduler Configuration

# ===========================
# Required Variables
# ===========================

# Vault path (absolute path to vault root)
VAULT_PATH="/absolute/path/to/vault"

# Schedules folder (auto-created if missing)
SCHEDULE_PATH="$VAULT_PATH/Schedules"

# Default timezone (IANA timezone identifier)
TIMEZONE_DEFAULT="UTC"

# ===========================
# Schedule Configuration
# ===========================

# Schedule format (cron | natural | iso8601)
SCHEDULE_FORMAT="cron"

# Reminder advance time in minutes
SCHEDULE_REMINDER_ADVANCE_MINUTES="15"

# Maximum occurrences limit (safety limit)
SCHEDULE_MAX_OCCURRENCES="1000"

# Default day for weekly audits
SCHEDULE_AUDIT_DAY="Sunday"

# Default time for daily briefings (24-hour format)
SCHEDULE_BRIEFING_TIME="09:00"

# ===========================
# Calendar Integration
# ===========================

# Calendar export format (ical | google | outlook)
CALENDAR_EXPORT_FORMAT="ical"

# Auto-generate calendar files on schedule creation
CALENDAR_AUTO_EXPORT="true"

# Calendar export location
CALENDAR_EXPORT_PATH="$VAULT_PATH/Calendars"

# ===========================
# Event Execution
# ===========================

# Agent responsible for executing scheduled events
EVENT_EXECUTOR_AGENT="lex"

# Minutes to start task before scheduled time
EVENT_PRE_EXECUTION_BUFFER_MINUTES="5"

# Max concurrent scheduled tasks
EVENT_PARALLEL_EXECUTION_LIMIT="3"

# Task execution timeout in seconds
EVENT_EXECUTION_TIMEOUT_SECONDS="300"

# ===========================
# Retry Configuration
# ===========================

# Enable retry on failure
SCHEDULE_RETRY_ON_FAILURE="false"

# Maximum retry attempts
SCHEDULE_MAX_RETRIES="3"

# Retry backoff base in milliseconds
SCHEDULE_RETRY_BACKOFF_MS="1000"

# ===========================
# Audit Trail
# ===========================

# Schedule audit log path
SCHEDULE_AUDIT_LOG_PATH="$VAULT_PATH/Audit_Logs/Schedules"

# Schedule history retention in days
SCHEDULE_HISTORY_RETENTION_DAYS="90"

# Enable verbose logging
SCHEDULE_VERBOSE_LOGGING="false"

# ===========================
# Performance Tuning
# ===========================

# Schedule evaluation interval in seconds (default: 60)
SCHEDULE_EVALUATION_INTERVAL_SECONDS="60"

# Enable schedule caching (reduces file reads)
SCHEDULE_ENABLE_CACHING="true"

# Cache TTL in seconds
SCHEDULE_CACHE_TTL_SECONDS="300"

# Maximum schedules to load in memory
SCHEDULE_MAX_LOADED="1000"

# ===========================
# External Integrations
# ===========================

# Google Calendar API (optional)
GOOGLE_CALENDAR_API_KEY=""
GOOGLE_CALENDAR_CALENDAR_ID=""

# Microsoft Outlook API (optional)
OUTLOOK_API_CLIENT_ID=""
OUTLOOK_API_CLIENT_SECRET=""

# Slack notifications (optional)
SLACK_WEBHOOK_URL=""
SLACK_DEFAULT_CHANNEL="#notifications"

# Email notifications (optional)
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""
EMAIL_FROM_ADDRESS="noreply@company.com"

# ===========================
# Feature Flags
# ===========================

# Enable natural language parsing
SCHEDULE_ENABLE_NATURAL_LANGUAGE="true"

# Enable calendar export
SCHEDULE_ENABLE_CALENDAR_EXPORT="true"

# Enable reminders
SCHEDULE_ENABLE_REMINDERS="true"

# Enable external integrations
SCHEDULE_ENABLE_EXTERNAL_INTEGRATIONS="false"

# ===========================
# Security
# ===========================

# Sanitize template content (prevent injection)
SCHEDULE_SANITIZE_TEMPLATES="true"

# Validate cron expressions before saving
SCHEDULE_VALIDATE_CRON="true"

# Validate timezone identifiers
SCHEDULE_VALIDATE_TIMEZONE="true"

# Enforce agent authorization
SCHEDULE_ENFORCE_AUTHORIZATION="true"

# Allowed agents (comma-separated)
SCHEDULE_ALLOWED_AGENTS="lex,orch"

# ===========================
# Monitoring
# ===========================

# Enable performance metrics
SCHEDULE_ENABLE_METRICS="true"

# Metrics export format (json | prometheus)
SCHEDULE_METRICS_FORMAT="json"

# Metrics export path
SCHEDULE_METRICS_PATH="$VAULT_PATH/Metrics"

# Alert on failed schedules
SCHEDULE_ALERT_ON_FAILURE="true"

# Alert email address
SCHEDULE_ALERT_EMAIL="ops@company.com"

# Alert threshold (failures before alerting)
SCHEDULE_ALERT_THRESHOLD="3"

# ===========================
# Development / Testing
# ===========================

# Enable debug mode
SCHEDULE_DEBUG="false"

# Mock time for testing (ISO 8601 timestamp)
SCHEDULE_MOCK_TIME=""

# Skip actual task execution (dry run)
SCHEDULE_DRY_RUN="false"

# Test mode (disable external integrations)
SCHEDULE_TEST_MODE="false"
