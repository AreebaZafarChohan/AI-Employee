# Error Recovery Planner - Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Vault path (inherited from vault_state_manager)
VAULT_PATH="/absolute/path/to/vault"

# ============================================================================
# RETRY CONFIGURATION
# ============================================================================

# Maximum number of automatic retry attempts before escalation
# Recommended: 3-5 for production, 1-2 for testing
RECOVERY_MAX_RETRIES="3"

# Base backoff delay in milliseconds (starting point for exponential/linear)
# Recommended: 1000-2000ms for most use cases
RECOVERY_BASE_BACKOFF_MS="1000"

# Maximum backoff delay in milliseconds (cap for exponential growth)
# Recommended: 300000ms (5 minutes) to prevent excessive delays
RECOVERY_MAX_BACKOFF_MS="300000"

# Jitter factor for randomizing backoff (0.0 = no jitter, 1.0 = 100% variance)
# Recommended: 0.2-0.3 for production to prevent thundering herd
# Set to 0.0 for deterministic testing
RECOVERY_JITTER_FACTOR="0.2"

# Backoff strategy: exponential | linear | fibonacci
# - exponential: Fast initial retries, slow later (good for transient errors)
# - linear: Constant spacing (good for rate limits)
# - fibonacci: Balanced growth (good for service degradation)
RECOVERY_STRATEGY="exponential"

# ============================================================================
# ERROR CLASSIFICATION
# ============================================================================

# Comma-separated list of error codes/patterns considered transient (retryable)
# These errors will trigger automatic retry with backoff
RECOVERY_TRANSIENT_ERROR_PATTERNS="ETIMEDOUT,ECONNRESET,ECONNREFUSED,503,429,502,504,EAGAIN,temporarily unavailable"

# Comma-separated list of error codes/patterns considered permanent (non-retryable)
# These errors will escalate immediately without retry
RECOVERY_PERMANENT_ERROR_PATTERNS="401,403,404,410,ENOENT,EINVAL,syntax error,invalid input"

# HTTP status codes that should trigger retry
RECOVERY_RETRY_HTTP_CODES="408,429,500,502,503,504"

# ============================================================================
# ESCALATION POLICIES
# ============================================================================

# Escalate to human after N failed retry attempts
# Should be <= RECOVERY_MAX_RETRIES
RECOVERY_ESCALATE_AFTER_ATTEMPTS="3"

# Escalate permanent errors immediately (bypass retry logic)
# Recommended: true (no point retrying permanent failures)
RECOVERY_ESCALATE_PERMANENT_ERRORS="true"

# Abandon task after N total retries across all attempts
# Safety net to prevent infinite retry loops
# Should be >= RECOVERY_MAX_RETRIES
RECOVERY_AUTO_ABANDON_THRESHOLD="5"

# ============================================================================
# RATE LIMIT HANDLING
# ============================================================================

# Default backoff for rate limit errors without Retry-After header
# Recommended: 60000ms (1 minute) for conservative rate limit recovery
RECOVERY_RATE_LIMIT_DEFAULT_BACKOFF_MS="60000"

# Honor Retry-After and X-RateLimit-Reset headers from APIs
# Recommended: true (respect server's retry guidance)
RECOVERY_HONOR_RATE_LIMIT_HEADERS="true"

# ============================================================================
# STORAGE & AUDIT
# ============================================================================

# Directory to store recovery plans (relative to VAULT_PATH)
RECOVERY_PLANS_PATH="$VAULT_PATH/Recovery_Plans"

# Audit log file for recovery decisions
RECOVERY_AUDIT_LOG="$VAULT_PATH/Audit_Logs/recovery.log"

# Retention period for recovery plans (days)
# Plans older than this will be archived by cleanup job
RECOVERY_PLAN_RETENTION_DAYS="30"

# Enable detailed logging of recovery decisions
RECOVERY_DEBUG_LOGGING="false"

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Minimum delay between retries (prevents too-fast retry storms)
# Even with exponential backoff, delay will never be less than this
RECOVERY_MIN_BACKOFF_MS="500"

# Enable recovery plan deduplication (prevent duplicate plans for same task)
RECOVERY_DEDUPLICATE_PLANS="true"

# Batch similar errors into single escalation (reduce human workload)
# If N+ tasks fail with same error within time window, create batch escalation
RECOVERY_BATCH_SIMILAR_ERRORS="true"
RECOVERY_BATCH_THRESHOLD="10"
RECOVERY_BATCH_WINDOW_MS="300000"  # 5 minutes

# Session ID for tracking recovery plans (optional)
RECOVERY_SESSION_ID=""

# ============================================================================
# EXAMPLES FOR DIFFERENT ENVIRONMENTS
# ============================================================================

# Development Environment (fast retries, short delays)
# RECOVERY_MAX_RETRIES="5"
# RECOVERY_BASE_BACKOFF_MS="500"
# RECOVERY_STRATEGY="linear"
# RECOVERY_JITTER_FACTOR="0.0"
# RECOVERY_DEBUG_LOGGING="true"

# Production Environment (conservative retries, longer delays)
# RECOVERY_MAX_RETRIES="3"
# RECOVERY_BASE_BACKOFF_MS="2000"
# RECOVERY_MAX_BACKOFF_MS="60000"
# RECOVERY_STRATEGY="exponential"
# RECOVERY_JITTER_FACTOR="0.3"
# RECOVERY_DEBUG_LOGGING="false"

# High-Availability Environment (aggressive retries, many attempts)
# RECOVERY_MAX_RETRIES="10"
# RECOVERY_BASE_BACKOFF_MS="1000"
# RECOVERY_MAX_BACKOFF_MS="300000"
# RECOVERY_STRATEGY="fibonacci"
# RECOVERY_JITTER_FACTOR="0.2"
# RECOVERY_AUTO_ABANDON_THRESHOLD="10"

# ============================================================================
# VALIDATION NOTES
# ============================================================================

# IMPACT: Changing RECOVERY_MAX_RETRIES affects how many times tasks retry
#   - Higher = more resilient to transient errors, but slower failure detection
#   - Lower = faster failure detection, but less resilient

# IMPACT: Changing RECOVERY_BASE_BACKOFF_MS affects retry speed
#   - Higher = less aggressive retries, less load on downstream services
#   - Lower = faster recovery, but risk of retry storms

# IMPACT: Changing RECOVERY_STRATEGY affects backoff growth pattern
#   - exponential = fast initial retries, slow later (good default)
#   - linear = constant spacing (predictable, good for rate limits)
#   - fibonacci = balanced (between exponential and linear)

# IMPACT: Enabling RECOVERY_JITTER_FACTOR prevents thundering herd
#   - Essential for production with multiple agents
#   - Disable in development/testing for deterministic behavior

# IMPACT: RECOVERY_AUTO_ABANDON_THRESHOLD prevents infinite retry loops
#   - Must be set to reasonable value (recommended 5-10)
#   - Acts as safety net for edge cases
