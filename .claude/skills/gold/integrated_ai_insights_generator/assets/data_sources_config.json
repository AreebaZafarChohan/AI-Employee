{
  "version": "1.0",
  "description": "Configuration file for defining data sources for AI insights generation",
  "data_sources": {
    "project_management": {
      "type": "jira",
      "enabled": true,
      "url": "https://your-company.atlassian.net",
      "api_token": "${JIRA_API_TOKEN}",
      "username": "${JIRA_USERNAME}",
      "projects": ["PROJ1", "PROJ2", "PROJ3"],
      "fields": ["summary", "status", "assignee", "created", "updated", "resolutiondate", "timespent", "timeestimate", "priority"],
      "query_filters": {
        "date_range": "last_90_days",
        "issue_types": ["Story", "Bug", "Task"]
      },
      "rate_limit": {
        "requests_per_minute": 60
      }
    },
    "system_logs": {
      "type": "file",
      "enabled": true,
      "path": "/var/log/application.log",
      "format": "json",
      "pattern": "\\[(?P<timestamp>[^\\]]+)\\] \\[(?P<level>\\w+)\\] (?P<message>.*)",
      "encoding": "utf-8",
      "refresh_interval_seconds": 30,
      "fields": ["timestamp", "level", "message", "component", "thread"]
    },
    "task_metrics": {
      "type": "database",
      "enabled": true,
      "connection_string": "${DATABASE_CONNECTION_STRING}",
      "table": "task_metrics",
      "query": "SELECT * FROM task_metrics WHERE created_at >= NOW() - INTERVAL '30 days'",
      "fields": ["task_id", "start_time", "end_time", "duration", "status", "assigned_to", "priority", "project_id"],
      "refresh_interval_seconds": 60
    },
    "ci_cd_metrics": {
      "type": "api",
      "enabled": true,
      "base_url": "https://your-ci-cd-platform.com/api/v1",
      "auth_token": "${CI_CD_API_TOKEN}",
      "endpoints": {
        "builds": "/builds?branch=main&status=completed&limit=100",
        "deployments": "/deployments?environment=production&limit=50"
      },
      "rate_limit": {
        "requests_per_minute": 30
      },
      "fields": ["id", "pipeline", "status", "duration", "commit_hash", "started_at", "finished_at", "environment"]
    }
  },
  "ai_configuration": {
    "provider": "openai",
    "model": "gpt-4",
    "api_key": "${OPENAI_API_KEY}",
    "temperature": 0.3,
    "max_tokens": 1000,
    "top_p": 1,
    "frequency_penalty": 0,
    "presence_penalty": 0,
    "request_timeout": 30
  },
  "analysis_settings": {
    "trend_analysis": {
      "enabled": true,
      "time_periods": ["7d", "30d", "90d"],
      "minimum_data_points": 10,
      "confidence_level": 0.95
    },
    "anomaly_detection": {
      "enabled": true,
      "algorithm": "isolation_forest",
      "sensitivity": 0.7,
      "features_to_analyze": ["response_time", "error_rate", "throughput"],
      "min_samples": 20
    },
    "benchmarking": {
      "enabled": true,
      "baseline_source": "historical_average",
      "comparison_metrics": ["velocity", "defect_rate", "cycle_time"],
      "update_frequency": "daily"
    },
    "root_cause_analysis": {
      "enabled": true,
      "max_depth": 3,
      "correlation_threshold": 0.5,
      "min_causal_relationships": 2
    }
  },
  "output_formats": {
    "dashboard": {
      "enabled": true,
      "template": "default_dashboard_template",
      "refresh_interval_minutes": 15,
      "widgets": [
        "metric_cards",
        "trend_charts",
        "anomaly_indicators",
        "comparison_tables"
      ]
    },
    "reports": {
      "enabled": true,
      "formats": ["pdf", "excel", "json"],
      "schedule": {
        "daily": "09:00",
        "weekly": "monday_08:00",
        "monthly": "first_day_08:00"
      }
    },
    "alerts": {
      "enabled": true,
      "thresholds": {
        "high": 0.9,
        "medium": 0.7,
        "low": 0.5
      },
      "delivery_channels": ["email", "slack", "teams"]
    }
  },
  "global_settings": {
    "default_timezone": "UTC",
    "data_retention_days": 365,
    "insight_cache_duration_minutes": 60,
    "max_insights_per_request": 20,
    "validation_enabled": true,
    "confidence_threshold": 0.7,
    "privacy_preserving": true,
    "debug_mode": false
  }
}