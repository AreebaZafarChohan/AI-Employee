# Agent Claim Coordinator - Environment Variables

# ============================================================================
# REQUIRED: Vault Path
# ============================================================================

# Vault root directory (absolute path)
VAULT_PATH="/absolute/path/to/vault"

# ============================================================================
# REQUIRED: Conflict Resolution Policy
# ============================================================================

# Policy for resolving claim conflicts
# Options: first_claim_wins | agent_priority | human_resolve
CLAIM_RESOLUTION_POLICY="first_claim_wins"

# ============================================================================
# OPTIONAL: Claim Timing
# ============================================================================

# Claim timeout (milliseconds) - how long before claim considered stale
CLAIM_TIMEOUT_MS="300000"  # 5 minutes

# Heartbeat update interval (milliseconds)
CLAIM_HEARTBEAT_INTERVAL_MS="30000"  # 30 seconds

# Grace period before reclaim (milliseconds)
RECLAIM_GRACE_PERIOD_MS="10000"  # 10 seconds

# ============================================================================
# OPTIONAL: Agent Priorities
# ============================================================================

# Agent priorities (comma-separated, lower number = higher priority)
# Only used if CLAIM_RESOLUTION_POLICY="agent_priority"
AGENT_PRIORITIES="orch:1,lex:2,cex:3,watcher:4"

# ============================================================================
# OPTIONAL: Conflict Detection
# ============================================================================

# How often to check for conflicts (milliseconds)
CONFLICT_CHECK_INTERVAL_MS="60000"  # 1 minute

# Automatically reclaim stale tasks
ENABLE_AUTOMATIC_RECLAIM="true"

# Mass reclaim threshold (0.0-1.0) - don't reclaim if >50% are stale
MASS_RECLAIM_THRESHOLD="0.5"

# ============================================================================
# OPTIONAL: Claim Thrashing Prevention
# ============================================================================

# Backoff after conflict loss (milliseconds)
CONFLICT_BACKOFF_BASE_MS="1000"  # 1 second (exponential: 1s, 2s, 4s, 8s...)
CONFLICT_BACKOFF_MAX_MS="60000"  # 60 seconds (max backoff)

# Rate limit per agent (claims per minute)
CLAIM_RATE_LIMIT="10"

# ============================================================================
# OPTIONAL: Clock Skew Tolerance
# ============================================================================

# Clock skew tolerance (milliseconds)
CLOCK_SKEW_TOLERANCE_MS="60000"  # 1 minute

# Use NTP for time synchronization
ENABLE_NTP_SYNC="true"
NTP_SERVER="pool.ntp.org"

# ============================================================================
# OPTIONAL: Logging
# ============================================================================

# Log level (debug | info | warn | error)
CLAIM_LOG_LEVEL="info"

# Log file paths (relative to VAULT_PATH or absolute)
CLAIM_LOG_FILE="${VAULT_PATH}/Logs/claims.log"
CONFLICT_LOG_FILE="${VAULT_PATH}/Logs/claim_conflicts.log"
RECLAIM_LOG_FILE="${VAULT_PATH}/Logs/reclaims.log"

# Log retention (days)
LOG_RETENTION_DAYS="30"

# ============================================================================
# OPTIONAL: Filesystem Options
# ============================================================================

# Enable file locking (for network filesystems)
ENABLE_FILE_LOCKING="false"

# Lock timeout (milliseconds)
LOCK_TIMEOUT_MS="10000"

# Lock retries
LOCK_RETRIES="3"

# ============================================================================
# OPTIONAL: Health Checks
# ============================================================================

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL_MS="30000"  # 30 seconds

# Enable circuit breaker for heartbeat updates
ENABLE_HEARTBEAT_CIRCUIT_BREAKER="true"

# Circuit breaker thresholds
CIRCUIT_BREAKER_ERROR_THRESHOLD="50"  # Percent
CIRCUIT_BREAKER_TIMEOUT_MS="5000"     # 5 seconds
CIRCUIT_BREAKER_RESET_TIMEOUT_MS="30000"  # 30 seconds

# ============================================================================
# OPTIONAL: Process Monitoring
# ============================================================================

# Enable process monitoring (immediate reclaim on process death)
ENABLE_PROCESS_MONITORING="true"

# Process check interval (milliseconds)
PROCESS_CHECK_INTERVAL_MS="10000"  # 10 seconds

# ============================================================================
# OPTIONAL: Notifications
# ============================================================================

# Enable human notifications for conflicts
ENABLE_CONFLICT_NOTIFICATIONS="true"

# Notification method (email | slack | webhook)
NOTIFICATION_METHOD="email"

# Notification recipients (comma-separated)
NOTIFICATION_RECIPIENTS="admin@example.com"

# Webhook URL (if NOTIFICATION_METHOD="webhook")
# NOTIFICATION_WEBHOOK_URL="https://example.com/webhook"

# ============================================================================
# OPTIONAL: Testing & Development
# ============================================================================

# Enable debug mode (verbose logging, no reclaims)
DEBUG_MODE="false"

# Dry run mode (log actions without executing)
DRY_RUN="false"

# Mock clock skew for testing (milliseconds)
# MOCK_CLOCK_SKEW_MS="60000"
