# Agent Delegation Manager - Environment Variables

# ============================================================================
# REQUIRED: Vault Paths
# ============================================================================

# Local vault root directory (absolute path)
VAULT_PATH_LOCAL="/absolute/path/to/local/vault"

# Cloud vault root directory (absolute path, synced by Dropbox/rsync/git)
VAULT_PATH_CLOUD="/absolute/path/to/cloud/vault"

# Local signal directory (for lex ↔ cex coordination)
SIGNALS_DIR_LOCAL="${VAULT_PATH_LOCAL}/.signals"

# Cloud signal directory (synced)
SIGNALS_DIR_CLOUD="${VAULT_PATH_CLOUD}/.signals"

# ============================================================================
# OPTIONAL: Delegation Policies
# ============================================================================

# Timeout for cloud agent response (milliseconds)
DELEGATION_TIMEOUT_MS="30000"

# Maximum retries for failed delegation
DELEGATION_MAX_RETRIES="3"

# Poll interval for checking cloud responses (milliseconds)
DELEGATION_SYNC_INTERVAL_MS="5000"

# Maximum delegation depth (prevent circular loops)
DELEGATION_MAX_DEPTH="3"

# ============================================================================
# OPTIONAL: Security Policies
# ============================================================================

# Pattern for detecting sensitive files (pipe-separated regex)
SECRETS_PATTERN="*.env|*secret*|*key*|*token*|*.pem|*.cert|*.p12"

# Auto-detect and mark secret files as local_only
AUTO_MARK_SECRETS="true"

# Allow approvals via cloud vault (false = local-only approvals)
ALLOW_CLOUD_APPROVAL="false"

# Enable HMAC signature validation for approval signals
ENABLE_APPROVAL_HMAC="false"

# Shared secret for HMAC (only if ENABLE_APPROVAL_HMAC=true)
# APPROVAL_HMAC_SECRET="your-shared-secret-here"

# ============================================================================
# OPTIONAL: Sync Health
# ============================================================================

# Maximum age for approval signatures (milliseconds)
APPROVAL_MAX_AGE_MS="3600000"  # 1 hour

# Clock skew tolerance (milliseconds)
CLOCK_SKEW_TOLERANCE_MS="60000"  # 1 minute

# Sync latency threshold for warnings (milliseconds)
SYNC_LATENCY_WARNING_MS="30000"  # 30 seconds

# ============================================================================
# OPTIONAL: Cleanup Policies
# ============================================================================

# Interval for cleanup jobs (milliseconds)
CLEANUP_INTERVAL_MS="60000"  # 1 minute

# Heartbeat interval for claimed signals (milliseconds)
HEARTBEAT_INTERVAL_MS="30000"  # 30 seconds

# Staleness threshold for reclaiming orphaned signals (milliseconds)
SIGNAL_STALE_THRESHOLD_MS="300000"  # 5 minutes

# ============================================================================
# OPTIONAL: Logging
# ============================================================================

# Log level (debug | info | warn | error)
DELEGATION_LOG_LEVEL="info"

# Log file paths (relative to vault root or absolute)
DELEGATION_LOG_FILE="${VAULT_PATH_LOCAL}/Logs/delegation.log"
APPROVAL_LOG_FILE="${VAULT_PATH_LOCAL}/Logs/approvals.log"
TIMEOUT_LOG_FILE="${VAULT_PATH_LOCAL}/Logs/delegation_timeouts.log"
ORPHAN_LOG_FILE="${VAULT_PATH_LOCAL}/Logs/orphaned_signals.log"
CONFLICT_LOG_FILE="${VAULT_PATH_LOCAL}/Logs/sync_conflicts.log"

# ============================================================================
# OPTIONAL: Agent Configuration
# ============================================================================

# Agent ID (unique identifier for this agent instance)
AGENT_ID="lex-${HOSTNAME}"

# Agent capabilities (comma-separated)
AGENT_CAPABILITIES="execute_local,read_secrets,file_operations"

# ============================================================================
# OPTIONAL: Conflict Resolution
# ============================================================================

# Sync conflict resolution policy
# Options: local_wins | cloud_wins | last_write_wins | merge | human_resolve
SYNC_CONFLICT_POLICY="human_resolve"

# ============================================================================
# OPTIONAL: Testing & Development
# ============================================================================

# Enable debug mode (verbose logging, no cleanup)
DEBUG_MODE="false"

# Dry run mode (log actions without executing)
DRY_RUN="false"

# Mock sync latency for testing (milliseconds)
# MOCK_SYNC_LATENCY_MS="5000"
