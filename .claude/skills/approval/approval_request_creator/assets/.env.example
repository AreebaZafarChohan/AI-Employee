# Approval Request Creator - Environment Variables

# ====================================
# Required Configuration
# ====================================

# Vault path (absolute path to Obsidian vault)
VAULT_PATH="/absolute/path/to/vault"

# Pending approval folder (auto-created if missing)
PENDING_APPROVAL_PATH="$VAULT_PATH/Pending_Approval"


# ====================================
# Approval Configuration
# ====================================

# Default timeout before escalation (hours)
APPROVAL_DEFAULT_TIMEOUT_HOURS="4"

# Require justification field (true/false)
APPROVAL_REQUIRE_REASON="true"

# Auto-escalate on timeout (true/false)
APPROVAL_AUTO_ESCALATE="true"


# ====================================
# Risk Thresholds
# ====================================

# Financial thresholds (USD)
APPROVAL_FINANCIAL_THRESHOLD="1000"          # Amount requiring approval
APPROVAL_CRITICAL_THRESHOLD="10000"          # Amount requiring C-level approval

# VIP customers (comma-separated)
APPROVAL_VIP_CUSTOMERS="customer1,customer2,vip_client"


# ====================================
# Notification Configuration (Optional)
# ====================================

# Email notifications
APPROVAL_NOTIFY_EMAIL="approver@company.com"
SMTP_HOST="smtp.company.com"
SMTP_PORT="587"
SMTP_USER="agent@company.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="AI Agent <agent@company.com>"
SMTP_TLS="true"

# Slack notifications
APPROVAL_NOTIFY_SLACK_WEBHOOK="https://hooks.slack.com/services/XXX/YYY/ZZZ"
APPROVAL_SLACK_CHANNEL="#approvals"

# SMS notifications (optional)
APPROVAL_NOTIFY_SMS="false"
APPROVAL_SMS_PROVIDER="twilio"
APPROVAL_SMS_PHONE="+1234567890"
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_PHONE="+0987654321"


# ====================================
# Escalation Configuration
# ====================================

# Escalation contacts
APPROVAL_ESCALATION_EMAIL="ceo@company.com"
APPROVAL_ESCALATION_SLACK_CHANNEL="#escalations"

# Escalation levels (comma-separated, in order)
APPROVAL_ESCALATION_CHAIN="manager@company.com,director@company.com,cfo@company.com,ceo@company.com"


# ====================================
# Audit Trail Configuration
# ====================================

# Audit log path (absolute path)
APPROVAL_AUDIT_LOG_PATH="$VAULT_PATH/Audit_Logs"

# Session ID (generated per agent session)
APPROVAL_SESSION_ID="session_$(date +%s)_$(uuidgen)"

# IP address (if available)
APPROVAL_IP_ADDRESS="127.0.0.1"

# User agent (agent identifier)
APPROVAL_USER_AGENT="lex/1.0.0"


# ====================================
# Archive Configuration
# ====================================

# Approval archive path
APPROVAL_ARCHIVE_PATH="$VAULT_PATH/Approval_Archive"

# Archive retention (days)
APPROVAL_ARCHIVE_RETENTION_DAYS="365"

# Auto-cleanup schedule (cron format: daily at 2 AM)
APPROVAL_CLEANUP_CRON="0 2 * * *"


# ====================================
# Approver Directory
# ====================================

# Manager approver
APPROVAL_MANAGER_EMAIL="manager@company.com"
APPROVAL_MANAGER_NAME="John Manager"

# Director approver
APPROVAL_DIRECTOR_EMAIL="director@company.com"
APPROVAL_DIRECTOR_NAME="Jane Director"

# VP approver
APPROVAL_VP_EMAIL="vp@company.com"
APPROVAL_VP_NAME="Bob VP"

# CFO approver
APPROVAL_CFO_EMAIL="cfo@company.com"
APPROVAL_CFO_NAME="Alice CFO"

# CTO approver
APPROVAL_CTO_EMAIL="cto@company.com"
APPROVAL_CTO_NAME="Charlie CTO"

# CEO approver
APPROVAL_CEO_EMAIL="ceo@company.com"
APPROVAL_CEO_NAME="Eve CEO"

# CISO approver (security)
APPROVAL_CISO_EMAIL="ciso@company.com"
APPROVAL_CISO_NAME="David CISO"


# ====================================
# Company Handbook Integration
# ====================================

# Company handbook path
HANDBOOK_PATH="$VAULT_PATH/Company_Handbook.md"

# Handbook version tracking
HANDBOOK_VERSION="v2.1.0"


# ====================================
# Feature Flags
# ====================================

# Enable/disable features
APPROVAL_ENABLE_EMAIL_NOTIFICATIONS="true"
APPROVAL_ENABLE_SLACK_NOTIFICATIONS="true"
APPROVAL_ENABLE_SMS_NOTIFICATIONS="false"
APPROVAL_ENABLE_DEDUPLICATION="true"
APPROVAL_ENABLE_AUTO_CLEANUP="true"


# ====================================
# Development/Testing Configuration
# ====================================

# Development mode (skip notifications, shorter timeouts)
APPROVAL_DEV_MODE="false"

# Mock notifications (log instead of sending)
APPROVAL_MOCK_NOTIFICATIONS="false"

# Override timeout (for testing, in minutes)
APPROVAL_TEST_TIMEOUT_MINUTES="5"
