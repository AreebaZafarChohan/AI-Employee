# CEO Briefing Writer - Environment Variables

# Data Source Paths
CEO_BRIEFING_GOALS_PATH="./goals/"
CEO_BRIEFING_DONE_PATH="./done/"
CEO_BRIEFING_FINANCIALS_PATH="./financials/"
CEO_BRIEFING_ISSUES_PATH="./issues/"

# Output Configuration
CEO_BRIEFING_OUTPUT_PATH="./CEO_Briefing.md"
CEO_BRIEFING_ARCHIVE_PATH="./archive/briefings/"

# Period Configuration
CEO_BRIEFING_PERIOD="weekly"  # Options: daily, weekly, monthly, quarterly
CEO_BRIEFING_TIMEZONE="UTC"   # e.g., "America/New_York", "Europe/London"

# Thresholds and Targets
CEO_BRIEFING_RUNWAY_WARNING="12"           # Months - warn when runway below this
CEO_BRIEFING_REVENUE_TARGET_MONTHLY="100000"  # USD - monthly revenue target
CEO_BRIEFING_BURN_RATE_BUDGET="150000"     # USD - monthly burn rate budget
CEO_BRIEFING_GOAL_AT_RISK_THRESHOLD="0.7"  # 0-1 - flag goals below 70% progress

# Health Score Weights (must sum to 1.0)
CEO_BRIEFING_FINANCIAL_WEIGHT="0.4"
CEO_BRIEFING_OPERATIONAL_WEIGHT="0.35"
CEO_BRIEFING_TEAM_WEIGHT="0.25"

# Recommendation Engine
CEO_BRIEFING_ENABLE_RECOMMENDATIONS="true"
CEO_BRIEFING_RECOMMENDATION_CONFIDENCE="high"  # Options: high, medium, low
CEO_BRIEFING_MAX_RECOMMENDATIONS="5"           # Maximum recommendations per briefing

# Bottleneck Detection
CEO_BRIEFING_MAX_CRITICAL_BOTTLENECKS="3"
CEO_BRIEFING_BOTTLENECK_SENSITIVITY="medium"  # Options: high, medium, low

# Formatting Options
CEO_BRIEFING_CURRENCY_SYMBOL="$"
CEO_BRIEFING_CURRENCY_LOCALE="en-US"
CEO_BRIEFING_DATE_FORMAT="MMMM DD, YYYY"
CEO_BRIEFING_USE_EMOJIS="true"

# Data Caching
CEO_BRIEFING_CACHE_ENABLED="true"
CEO_BRIEFING_CACHE_TTL="3600"  # Seconds - 1 hour

# Audit and Logging
CEO_BRIEFING_AUDIT_LOG_PATH="./logs/briefing_audit.log"
CEO_BRIEFING_LOG_LEVEL="info"  # Options: debug, info, warn, error

# Optional: External Integrations
# CEO_BRIEFING_SLACK_WEBHOOK=""
# CEO_BRIEFING_EMAIL_RECIPIENTS=""
# CEO_BRIEFING_JIRA_URL=""
# CEO_BRIEFING_JIRA_TOKEN=""
