# Dashboard Writer Configuration
# Copy this file to .env and fill in your values

# Data Sources
DASHBOARD_DONE_FOLDER=./done/                # Path to completed tasks folder
DASHBOARD_TIME_TRACKING_FOLDER=./logs/time/  # Time tracking logs (optional)
DASHBOARD_DEPLOYMENT_LOGS=./logs/deploy/     # Deployment logs (optional)

# Output Configuration
DASHBOARD_PATH=./Dashboard.md                # Where to write dashboard
DASHBOARD_ARCHIVE_PATH=./archive/dashboards/ # Archive previous versions

# Period Configuration
DASHBOARD_DEFAULT_PERIOD=weekly              # daily | weekly | monthly | quarterly
DASHBOARD_TIMEZONE=America/Los_Angeles       # Timezone for date calculations
WEEK_STARTS_ON=1                             # 0=Sunday, 1=Monday, ..., 6=Saturday

# Metric Targets (for status indicators)
DASHBOARD_RESPONSE_TIME_TARGET=4             # Target response time (hours)
DASHBOARD_DEPLOYMENT_SUCCESS_TARGET=95       # Target success rate (percent)
DASHBOARD_TEST_COVERAGE_TARGET=80            # Target test coverage (percent)
DASHBOARD_TASKS_PER_WEEK_TARGET=12           # Target weekly task completion

# Financial Configuration
DASHBOARD_REVENUE_TARGET_WEEKLY=10000        # Weekly revenue target (USD)
DASHBOARD_REVENUE_TARGET_MONTHLY=45000       # Monthly revenue target (USD)
DASHBOARD_BURN_RATE_BUDGET=50000             # Monthly budget (USD)

# Budget Categories (optional)
DASHBOARD_BUDGET_ENGINEERING=30000           # Engineering monthly budget
DASHBOARD_BUDGET_OPERATIONS=10000            # Operations monthly budget
DASHBOARD_BUDGET_MARKETING=10000             # Marketing monthly budget

# External Integrations (optional)

# GitHub Integration
GITHUB_TOKEN=ghp_your_token_here             # GitHub personal access token
GITHUB_OWNER=your-org                        # GitHub organization/user
GITHUB_REPO=your-repo                        # GitHub repository

# Jira Integration (optional)
# JIRA_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your_jira_api_token

# Time Tracking API (optional)
# TIME_TRACKING_API=https://api.toggl.com/api/v9
# TIME_TRACKING_TOKEN=your_toggl_token

# Notification Configuration (optional)

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#dashboard-updates             # Channel for notifications

# Email Notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your_app_password
# DASHBOARD_EMAIL_TO=team@company.com

# Scheduled Updates (cron format)
DASHBOARD_SCHEDULE_DAILY=0 17 * * *          # Daily at 5 PM
DASHBOARD_SCHEDULE_WEEKLY=0 9 * * 1          # Monday at 9 AM
DASHBOARD_SCHEDULE_MONTHLY=0 9 1 * *         # 1st of month at 9 AM

# Display Options
DASHBOARD_USE_UNICODE=true                   # Use Unicode progress bars (true/false)
DASHBOARD_MAX_RECENT_TASKS=10                # Max tasks to show in "Recent Activities"
DASHBOARD_MAX_UPCOMING_DEADLINES=5           # Max deadlines to show in "Upcoming"

# Performance Options
DASHBOARD_PARALLEL_FILE_READ=true            # Read task files in parallel
DASHBOARD_FILE_READ_BATCH_SIZE=50            # Files per batch (if parallel)
DASHBOARD_CACHE_ENABLED=true                 # Enable metric caching
DASHBOARD_CACHE_TTL=3600                     # Cache TTL in seconds (1 hour)

# Data Filtering
DASHBOARD_EXCLUDE_TYPES=                     # Comma-separated task types to exclude
DASHBOARD_MIN_TASK_DURATION=0                # Minimum duration to include (hours)

# Outlier Detection
DASHBOARD_OUTLIER_DETECTION=true             # Enable outlier detection
DASHBOARD_OUTLIER_STD_DEV=2                  # Standard deviations for outlier threshold

# Debug Options
DASHBOARD_DEBUG=false                        # Enable debug logging
DASHBOARD_DRY_RUN=false                      # Generate but don't write file
DASHBOARD_VERBOSE=false                      # Verbose output

# IMPORTANT: Production settings
# - Set DASHBOARD_TIMEZONE to match your team's location
# - Configure targets based on your team's capacity
# - Set up Slack webhook for team visibility
# - Enable caching for performance
# - Use daily/weekly schedules for consistent updates
