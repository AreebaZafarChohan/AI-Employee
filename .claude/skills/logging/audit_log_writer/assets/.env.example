# Audit Log Writer - Environment Variables

# ============================================================================
# REQUIRED: Vault and Logs Path
# ============================================================================

# Vault root directory (absolute path)
VAULT_PATH="/absolute/path/to/vault"

# Logs directory (relative to VAULT_PATH or absolute)
LOGS_DIR="${VAULT_PATH}/Logs"

# ============================================================================
# OPTIONAL: Log Rotation
# ============================================================================

# Archive logs older than this many days
LOG_ROTATION_DAYS="90"

# Compress archived logs
ENABLE_LOG_COMPRESSION="true"

# Archive directory
LOG_ARCHIVE_DIR="${LOGS_DIR}/archive"

# ============================================================================
# OPTIONAL: Log Retention
# ============================================================================

# Delete logs older than this many days
LOG_RETENTION_DAYS="365"

# Enable automatic cleanup
ENABLE_AUTO_CLEANUP="true"

# Cleanup schedule (cron format)
CLEANUP_SCHEDULE="0 3 * * 0"  # Weekly at 3 AM Sunday

# ============================================================================
# OPTIONAL: Log Integrity
# ============================================================================

# Enable log integrity checking (checksums)
ENABLE_LOG_INTEGRITY_CHECK="true"

# Checksum algorithm (sha256 | sha512 | md5)
LOG_CHECKSUM_ALGORITHM="sha256"

# Checksum directory
LOG_CHECKSUM_DIR="${LOGS_DIR}/.checksums"

# ============================================================================
# OPTIONAL: Performance
# ============================================================================

# Buffer log entries before flushing to disk
LOG_BUFFER_SIZE="100"

# Flush buffer every N milliseconds
LOG_FLUSH_INTERVAL_MS="5000"

# Enable async logging (non-blocking writes)
ENABLE_ASYNC_LOGGING="true"

# ============================================================================
# OPTIONAL: Privacy & Security
# ============================================================================

# Enable PII redaction
ENABLE_PII_REDACTION="true"

# PII patterns to redact (pipe-separated regex)
PII_PATTERNS="email|ssn|phone|credit_card"

# Enable secret redaction
ENABLE_SECRET_REDACTION="true"

# Secret patterns to redact
SECRET_PATTERNS="api_key|token|password|secret|credential"

# ============================================================================
# OPTIONAL: Log Format
# ============================================================================

# Log format (jsonl | json | pretty)
LOG_FORMAT="jsonl"  # JSON Lines (one JSON object per line)

# Pretty print JSON (only if LOG_FORMAT="pretty")
LOG_PRETTY_PRINT="false"

# ============================================================================
# OPTIONAL: Monitoring & Alerts
# ============================================================================

# Alert on high log write failure rate (%)
LOG_WRITE_FAILURE_THRESHOLD="1"

# Alert on log tampering detection
ALERT_ON_LOG_TAMPERING="true"

# Alert on disk usage (%)
DISK_USAGE_ALERT_THRESHOLD="90"

# ============================================================================
# OPTIONAL: Testing & Development
# ============================================================================

# Enable debug mode (verbose logging to console)
DEBUG_MODE="false"

# Dry run mode (don't write logs, just print to console)
DRY_RUN="false"

# Mock timestamp for testing
# MOCK_TIMESTAMP="2025-01-15T10:00:00.000Z"
