{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Audit Log Entry Template",
  "description": "Template for structured audit log entries",
  "required": ["timestamp", "agent_id", "action", "outcome"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the event",
      "examples": ["{{TIMESTAMP}}"]
    },
    "agent_id": {
      "type": "string",
      "pattern": "^agent-[a-zA-Z0-9-_]+$",
      "description": "Unique identifier of the agent performing the action",
      "examples": ["{{AGENT_ID}}"]
    },
    "task_id": {
      "type": "string",
      "description": "Identifier of the task being operated on (optional)",
      "examples": ["{{TASK_ID}}"]
    },
    "action": {
      "type": "string",
      "enum": [
        "task_created", "task_claimed", "task_started", "task_completed", 
        "task_failed", "task_released", "config_changed", "access_granted", 
        "access_denied", "data_accessed", "data_modified", "system_event"
      ],
      "description": "Type of action being logged",
      "examples": ["{{ACTION}}"]
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "failure", "partial"],
      "description": "Result of the action",
      "examples": ["{{OUTCOME}}"]
    },
    "source_ip": {
      "type": "string",
      "format": "ipv4",
      "description": "IP address of the request originator"
    },
    "session_id": {
      "type": "string",
      "description": "Correlation ID for multi-step operations"
    },
    "correlation_id": {
      "type": "string",
      "description": "Additional correlation identifier"
    },
    "metadata": {
      "type": "object",
      "description": "Action-specific contextual information",
      "properties": {
        "duration_ms": {
          "type": "integer",
          "description": "Duration of the action in milliseconds"
        },
        "previous_owner": {
          "type": "string",
          "description": "Previous owner of the task (for claim/release actions)"
        },
        "claim_strategy": {
          "type": "string",
          "description": "Strategy used for task claiming"
        },
        "error_message": {
          "type": "string",
          "description": "Error message if action failed"
        },
        "error_type": {
          "type": "string",
          "description": "Type of error that occurred"
        }
      }
    },
    "version": {
      "type": "string",
      "description": "Schema version for the log entry",
      "default": "1.0.0"
    }
  },
  "example_log_entry": {
    "timestamp": "{{TIMESTAMP}}",
    "agent_id": "{{AGENT_ID}}",
    "task_id": "{{TASK_ID}}",
    "action": "{{ACTION}}",
    "outcome": "{{OUTCOME}}",
    "source_ip": "192.168.1.100",
    "session_id": "sess-abc123def456",
    "correlation_id": "corr-xyz789",
    "metadata": {
      "duration_ms": 150,
      "previous_owner": "agent-processor-02",
      "claim_strategy": "load_balanced",
      "error_message": "Connection timeout",
      "error_type": "TimeoutError"
    },
    "version": "1.0.0"
  }
}