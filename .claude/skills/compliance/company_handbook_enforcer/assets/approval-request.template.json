    "requested_at": "{{ISO_TIMESTAMP}}",
    "approver_notified_at": null,
    "approver_viewed_at": null,
    "decision_made_at": null,
    "action_executed_at": null
  },

  "notifications": {
    "email": {
      "to": "{{APPROVER_EMAIL}}",
