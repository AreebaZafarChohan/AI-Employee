      "sent": "{{true|false}}",
      "sent_at": "{{ISO_TIMESTAMP}}"
    },
    "slack": {
      "channel": "{{SLACK_CHANNEL}}",
      "webhook_url": "{{SLACK_WEBHOOK_URL}}",
      "sent": "{{true|false}}",
      "sent_at": "{{ISO_TIMESTAMP}}"
    },
    "sms": {
      "enabled": "{{true|false}}",
      "phone": "{{APPROVER_PHONE}}",
      "sent": "{{true|false}}",
      "sent_at": "{{ISO_TIMESTAMP}}"
    }
