# Company Handbook Enforcer Configuration
# Copy this file to .env and fill in your values

# Handbook Location
HANDBOOK_PATH=./Company_Handbook.md

# Enforcement Level
# STRICT: Block all violations (production default)
# WARN: Log violations but allow action (staging/dev)
# SUGGEST: Provide alternatives without blocking (advisory mode)
HANDBOOK_ENFORCEMENT_LEVEL=STRICT

# Cache Configuration
HANDBOOK_CACHE_TTL=300  # seconds (5 minutes)
HANDBOOK_CACHE_MAX_SIZE=100  # max cached policy sets

# Approval Workflow
HANDBOOK_APPROVAL_TIMEOUT=14400  # seconds (4 hours)
HANDBOOK_APPROVAL_WEBHOOK_URL=https://api.company.com/approvals
HANDBOOK_APPROVAL_WEBHOOK_SECRET=change_me_in_production

# Escalation Configuration
HANDBOOK_ESCALATION_WEBHOOK_URL=https://api.company.com/escalations
HANDBOOK_ESCALATION_EMAIL=compliance@company.com
HANDBOOK_ESCALATION_SLACK_CHANNEL=#compliance-alerts

# Audit Logging
HANDBOOK_AUDIT_LOG_PATH=./logs/audit.jsonl
HANDBOOK_AUDIT_LOG_LEVEL=info  # debug | info | warn | error
HANDBOOK_AUDIT_LOG_ROTATION=daily  # daily | weekly | size
HANDBOOK_AUDIT_LOG_MAX_SIZE=100M  # if rotation=size

# Database Configuration (if using external audit log)
# HANDBOOK_AUDIT_DB_HOST=localhost
# HANDBOOK_AUDIT_DB_PORT=5432
# HANDBOOK_AUDIT_DB_NAME=compliance_audit
# HANDBOOK_AUDIT_DB_USER=audit_user
# HANDBOOK_AUDIT_DB_PASSWORD=change_me_in_production

# Alert Configuration
HANDBOOK_ALERT_CRITICAL_VIOLATIONS=true
HANDBOOK_ALERT_EMAIL=compliance-alerts@company.com
HANDBOOK_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Performance Optimization
HANDBOOK_PARALLEL_VALIDATION=true  # validate multiple policies in parallel
HANDBOOK_EARLY_EXIT_ON_CRITICAL=true  # stop validation on first critical violation

# Environment Detection (auto-set enforcement level if not specified)
NODE_ENV=production  # production | staging | development

# Handbook Version Tracking
HANDBOOK_VERSION_CHECK=true  # verify handbook version before validation
HANDBOOK_MIN_VERSION=1.0.0  # minimum required handbook version

# Feature Flags
HANDBOOK_ENABLE_TEMPLATE_ALTERNATIVES=true
HANDBOOK_ENABLE_INCREMENTAL_FIXES=true
HANDBOOK_ENABLE_CONTEXT_AWARE_VALIDATION=true

# Integration Configuration
# PII Detection Service (if using external service)
# HANDBOOK_PII_DETECTION_URL=https://api.company.com/pii-detect
# HANDBOOK_PII_DETECTION_API_KEY=change_me_in_production

# Currency Conversion Service (for multi-currency financial policies)
# HANDBOOK_EXCHANGE_RATE_API_URL=https://api.exchangerate.com
# HANDBOOK_EXCHANGE_RATE_API_KEY=change_me_in_production

# Document Generation Service (for compliance reports)
# HANDBOOK_REPORT_GENERATOR_URL=https://api.company.com/reports
# HANDBOOK_REPORT_GENERATOR_API_KEY=change_me_in_production

# Monitoring and Observability
HANDBOOK_METRICS_ENABLED=true
HANDBOOK_METRICS_PORT=9090  # Prometheus metrics endpoint
HANDBOOK_TRACING_ENABLED=true  # OpenTelemetry tracing
HANDBOOK_TRACING_ENDPOINT=http://localhost:4318  # OTLP endpoint

# Development/Testing Configuration
HANDBOOK_MOCK_APPROVALS=false  # auto-approve in dev/test (NEVER in production)
HANDBOOK_TEST_MODE=false  # skip certain validations in test mode
HANDBOOK_DRY_RUN=false  # log what would happen without enforcing

# IMPORTANT: In production, ensure:
# - HANDBOOK_ENFORCEMENT_LEVEL=STRICT
# - HANDBOOK_MOCK_APPROVALS=false
# - HANDBOOK_TEST_MODE=false
# - HANDBOOK_DRY_RUN=false
# - All webhook URLs and secrets configured
# - Audit logging enabled and secured
