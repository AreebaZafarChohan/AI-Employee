# IMPACT NOTES:
# - Copy this file to .env (not committed to repo)
# - Replace {{VARIABLE}} with actual values
# - {{SECRET_*}} variables must be changed in production
# - This example uses realistic placeholders, not real secrets

# Application Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=myappdb
DATABASE_USER=appuser
# {{SECRET_DATABASE_PASSWORD}} - Change in production!
DATABASE_PASSWORD=postgrespassword
# Constructed URL - don't edit this
DATABASE_URL=postgresql://appuser:postgrespassword@postgres:5432/myappdb

# Cache Configuration
CACHE_HOST=redis
CACHE_PORT=6379
CACHE_URL=redis://redis:6379

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
# For multiple origins, use comma-separated list
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Feature Flags
ENABLE_METRICS=false
METRICS_PORT=9090

# Authentication
# {{SECRET_JWT_SECRET}} - Generate strong random string for production!
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# OAuth Configuration (example)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# External APIs
# API_KEY=your-api-key
# {{SECRET_API_KEY}} - Add real key in production .env

# Service Names (for Docker/K8s service discovery)
DATABASE_SERVICE_NAME=postgres
CACHE_SERVICE_NAME=redis
API_SERVICE_NAME=web

# Timezone
TZ=UTC
