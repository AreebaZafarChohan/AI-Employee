# Transaction Classifier Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# REQUIRED: Vault Configuration
# ============================================================================

# Absolute path to vault directory
VAULT_PATH="/absolute/path/to/vault"

# Transaction analysis output directory (auto-created if missing)
TRANSACTION_ANALYSIS_PATH="$VAULT_PATH/Transaction_Analysis"

# ============================================================================
# OPTIONAL: Classification Configuration
# ============================================================================

# Confidence threshold for auto-approval (0.0-1.0)
# Transactions below this threshold will be flagged for manual review
# Default: 0.70
TRANSACTION_CONFIDENCE_THRESHOLD="0.70"

# Anomaly detection threshold (standard deviations)
# Transactions exceeding this many standard deviations from mean are flagged
# Default: 3.0
TRANSACTION_ANOMALY_THRESHOLD="3.0"

# Auto-approve threshold (0.0-1.0)
# Transactions with confidence above this are automatically approved
# Default: 0.95
TRANSACTION_AUTO_APPROVE_THRESHOLD="0.95"

# ============================================================================
# OPTIONAL: Category Customization
# ============================================================================

# Custom categories (comma-separated)
# Add domain-specific categories beyond default: revenue, expense, subscription, anomaly
# Example: "client_reimbursement,tax_payment,investment"
TRANSACTION_CUSTOM_CATEGORIES=""

# Subscription detection patterns (comma-separated regex)
# Merchant name patterns that indicate subscription services
# Example: ".*SPOTIFY.*,.*NETFLIX.*,.*GITHUB.*"
TRANSACTION_SUBSCRIPTION_PATTERNS=""

# Merchant name aliases (JSON format)
# Map variations of merchant names to canonical names
# Example: {"AMZN MKTP US":"Amazon","AMZN.COM":"Amazon"}
TRANSACTION_MERCHANT_ALIASES=""

# ============================================================================
# OPTIONAL: Output Configuration
# ============================================================================

# Output format: markdown | json | csv
# Default: markdown
TRANSACTION_OUTPUT_FORMAT="markdown"

# Include actionable suggestions in output
# Default: true
TRANSACTION_INCLUDE_SUGGESTIONS="true"

# Show confidence scores in output
# Default: true
TRANSACTION_INCLUDE_CONFIDENCE="true"

# Include historical context for recurring merchants
# Default: true
TRANSACTION_INCLUDE_HISTORICAL="true"

# Include statistical analysis (z-scores, percentiles)
# Default: true
TRANSACTION_INCLUDE_STATISTICS="true"

# ============================================================================
# OPTIONAL: Anomaly Detection Settings
# ============================================================================

# Anomaly sensitivity: low | medium | high
# Default: medium
TRANSACTION_ANOMALY_SENSITIVITY="medium"

# Flag patterns (comma-separated)
# Patterns to flag: unusual_time, large_amount, unknown_merchant, overseas, duplicate
# Default: all patterns enabled
TRANSACTION_FLAG_PATTERNS="unusual_time,large_amount,unknown_merchant,overseas,duplicate"

# Baseline period for anomaly detection (days)
# Number of days of historical data to use for baseline calculations
# Default: 90
TRANSACTION_BASELINE_PERIOD_DAYS="90"

# Large transaction threshold (absolute amount)
# Transactions above this amount are flagged as potentially large/unusual
# Default: 1000.00
TRANSACTION_LARGE_AMOUNT_THRESHOLD="1000.00"

# ============================================================================
# OPTIONAL: Compliance and Security
# ============================================================================

# Require manual review for all classifications
# Default: false (only low-confidence transactions require review)
TRANSACTION_REQUIRE_REVIEW="false"

# Retain raw transaction data in classified files
# Default: true
TRANSACTION_RETAIN_RAW_DATA="true"

# Audit log path for classification events
TRANSACTION_AUDIT_LOG_PATH="$VAULT_PATH/Audit_Logs"

# Current agent session ID (auto-populated by agent)
TRANSACTION_SESSION_ID=""

# Redact sensitive fields in logs (comma-separated field names)
# Example: "account_number,routing_number,full_name"
TRANSACTION_REDACT_FIELDS=""

# ============================================================================
# OPTIONAL: Integration Settings
# ============================================================================

# External accounting system export format
# Options: quickbooks | xero | csv | none
# Default: none
TRANSACTION_EXPORT_FORMAT="none"

# Accounting system API endpoint (if applicable)
TRANSACTION_ACCOUNTING_API_URL=""

# Enable real-time classification notifications
# Default: false
TRANSACTION_ENABLE_NOTIFICATIONS="false"

# Notification webhook URL (for anomaly alerts)
TRANSACTION_NOTIFICATION_WEBHOOK=""

# ============================================================================
# OPTIONAL: Performance Tuning
# ============================================================================

# Maximum batch size for CSV processing
# Default: 1000
TRANSACTION_MAX_BATCH_SIZE="1000"

# Classification timeout per transaction (milliseconds)
# Default: 5000
TRANSACTION_CLASSIFICATION_TIMEOUT="5000"

# Enable parallel processing for batch classifications
# Default: true
TRANSACTION_ENABLE_PARALLEL="true"

# Maximum parallel workers
# Default: 4
TRANSACTION_MAX_WORKERS="4"

# ============================================================================
# OPTIONAL: Currency and Localization
# ============================================================================

# Default currency code (ISO 4217)
# Default: USD
TRANSACTION_DEFAULT_CURRENCY="USD"

# Enable multi-currency support
# Default: false
TRANSACTION_MULTI_CURRENCY="false"

# Currency conversion API (if multi-currency enabled)
TRANSACTION_CURRENCY_API_KEY=""

# Date format for transaction dates
# Default: YYYY-MM-DD
TRANSACTION_DATE_FORMAT="YYYY-MM-DD"

# Timezone for timestamp localization
# Default: UTC
TRANSACTION_TIMEZONE="UTC"

# ============================================================================
# OPTIONAL: Machine Learning Model Settings
# ============================================================================

# Classification model version
# Default: v1.0
TRANSACTION_MODEL_VERSION="v1.0"

# Model update frequency (days)
# How often to retrain model with new data
# Default: 30
TRANSACTION_MODEL_UPDATE_FREQUENCY="30"

# Minimum training samples required per category
# Default: 50
TRANSACTION_MIN_TRAINING_SAMPLES="50"

# ============================================================================
# DEVELOPMENT / DEBUG
# ============================================================================

# Enable debug logging
# Default: false
TRANSACTION_DEBUG="false"

# Log level: error | warn | info | debug
# Default: info
TRANSACTION_LOG_LEVEL="info"

# Dry run mode (classify but don't write files)
# Default: false
TRANSACTION_DRY_RUN="false"
