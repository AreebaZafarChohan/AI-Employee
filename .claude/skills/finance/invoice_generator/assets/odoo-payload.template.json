{
  "jsonrpc": "2.0",
  "method": "call",
  "params": {
    "service": "object",
    "method": "execute",
    "args": [
      "{{ODOO_DATABASE}}",
      "{{ODOO_USER_ID}}",
      "{{ODOO_PASSWORD}}",
      "account.move",
      "create",
      {
        "move_type": "out_invoice",
        "partner_id": {{ODOO_PARTNER_ID}},
        "invoice_date": "{{INVOICE_DATE}}",
        "invoice_date_due": "{{DUE_DATE}}",
        "ref": "{{INVOICE_NUMBER}}",
        "journal_id": {{ODOO_JOURNAL_ID}},
        "currency_id": {{ODOO_CURRENCY_ID}},
        "payment_term_id": {{ODOO_PAYMENT_TERM_ID}},
        "invoice_line_ids": [
          {{#each INVOICE_LINES}}
          {
            "name": "{{this.description}}",
            "quantity": {{this.quantity}},
            "price_unit": {{this.rate}},
            "account_id": {{this.account_id}},
            "tax_ids": [[6, 0, [{{#if this.taxable}}{{../ODOO_TAX_ID}}{{/if}}]]],
            "analytic_account_id": {{#if this.analytic_account_id}}{{this.analytic_account_id}}{{else}}false{{/if}}
          }{{#unless @last}},{{/unless}}
          {{/each}}
        ],
        "narration": "{{INVOICE_NOTES}}\n\nGenerated by Invoice Generator v{{SKILL_VERSION}}."
      }
    ]
  },
  "id": "invoice_generator_{{INVOICE_NUMBER}}"
}
