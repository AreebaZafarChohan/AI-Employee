# Invoice Generator - Environment Configuration

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Vault path (absolute path to your vault directory)
VAULT_PATH="/absolute/path/to/vault"

# Invoice output directory (auto-created if missing)
INVOICE_OUTPUT_PATH="$VAULT_PATH/Invoices"

# Company Information (REQUIRED)
INVOICE_COMPANY_NAME="Your Company Name Inc"
INVOICE_COMPANY_EMAIL="billing@yourcompany.com"
INVOICE_COMPANY_ADDRESS="123 Main Street, Suite 100, City, State, ZIP"
INVOICE_COMPANY_PHONE="+1-555-123-4567"
INVOICE_TAX_ID="12-3456789"  # EIN or VAT number

# =============================================================================
# INVOICE DEFAULTS
# =============================================================================

# Currency (ISO 4217 code)
INVOICE_DEFAULT_CURRENCY="USD"

# Payment terms
INVOICE_DEFAULT_PAYMENT_TERMS="Net 30"  # Options: Net 15, Net 30, Net 60, Due on Receipt

# Tax rate (decimal format: 0.08 = 8%)
INVOICE_DEFAULT_TAX_RATE="0.08"

# Late fee (monthly percentage)
INVOICE_LATE_FEE_PERCENT="1.5"

# Grace period before late fees apply (days)
INVOICE_LATE_FEE_GRACE_DAYS="5"

# Early payment discount
INVOICE_DISCOUNT_ENABLED="true"
INVOICE_EARLY_PAYMENT_DISCOUNT="2.0"  # 2% discount
INVOICE_DISCOUNT_PERIOD_DAYS="10"     # If paid within 10 days

# =============================================================================
# INVOICE NUMBERING
# =============================================================================

# Invoice number prefix
INVOICE_NUMBER_PREFIX="INV-"

# Starting invoice number
INVOICE_NUMBER_START="10001"

# Date format for invoices (YYYY-MM-DD recommended)
INVOICE_DATE_FORMAT="YYYY-MM-DD"

# Include company logo
INVOICE_INCLUDE_LOGO="false"
INVOICE_LOGO_PATH=""  # Path to logo file (if enabled)

# =============================================================================
# PAYMENT INFORMATION
# =============================================================================

# Bank Transfer (Domestic)
INVOICE_BANK_ACCOUNT_NAME="Your Company Name Inc"
INVOICE_BANK_ACCOUNT_NUMBER="XXXX-XXXX-1234"
INVOICE_BANK_ROUTING_NUMBER="123456789"

# Wire Transfer (International)
INVOICE_SWIFT_CODE="ABCDUS33XXX"
INVOICE_WIRE_ACCOUNT_NUMBER="1234567890"

# International Banking (Optional)
INVOICE_IBAN=""
INVOICE_BANK_NAME=""
INVOICE_BANK_ADDRESS=""

# Check Payment
INVOICE_CHECK_MAILING_ADDRESS="123 Main Street, City, State, ZIP"

# Online Payment Link (Optional)
INVOICE_INCLUDE_PAYMENT_LINK="false"
INVOICE_PAYMENT_LINK_URL=""

# =============================================================================
# ODOO ERP INTEGRATION (Optional)
# =============================================================================

# Odoo server configuration
ODOO_API_URL=""  # e.g., https://your-company.odoo.com
ODOO_DATABASE=""
ODOO_USER_ID=""
ODOO_PASSWORD=""  # Store in secure vault, not here!

# Odoo default accounts
ODOO_ACCOUNT_ID=""     # Default revenue account ID
ODOO_JOURNAL_ID=""     # Default sales journal ID
ODOO_CURRENCY_ID="1"   # 1 = USD (adjust for your currency)
ODOO_TAX_ID=""         # Default tax ID

# =============================================================================
# OUTPUT PREFERENCES
# =============================================================================

# Output format
INVOICE_OUTPUT_FORMAT="markdown"  # Options: markdown, json, html

# PDF generation hints
INVOICE_GENERATE_PDF_HINTS="true"

# Attach detailed timesheet
INVOICE_ATTACH_TIMESHEETS="true"

# Include payment link in invoice
INVOICE_INCLUDE_PAYMENT_LINK="false"

# =============================================================================
# COMPLIANCE AND AUDIT
# =============================================================================

# Audit logging
INVOICE_AUDIT_LOG_PATH="$VAULT_PATH/Audit_Logs"

# Retention period (years)
INVOICE_RETENTION_YEARS="7"

# Require approval for invoices above threshold
INVOICE_REQUIRE_APPROVAL="false"
INVOICE_APPROVAL_THRESHOLD="10000"  # Dollar amount

# Current session ID (for tracking)
INVOICE_SESSION_ID=""

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Multi-currency support
INVOICE_MULTI_CURRENCY_ENABLED="false"

# Exchange rate API (if using multi-currency)
INVOICE_EXCHANGE_RATE_API_URL=""
INVOICE_EXCHANGE_RATE_API_KEY=""

# Tax handling
INVOICE_TAX_INCLUSIVE="false"  # Are prices tax-inclusive?
INVOICE_REVERSE_CHARGE_ENABLED="false"  # EU B2B reverse charge

# Rounding precision
INVOICE_ROUNDING_DECIMALS="2"

# Concurrent invoice generation locking
INVOICE_USE_LOCKING="true"
INVOICE_LOCK_TIMEOUT_MS="5000"

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Email notifications for invoice events
INVOICE_NOTIFY_ON_GENERATION="false"
INVOICE_NOTIFY_EMAIL=""

# Send copy of invoices to internal team
INVOICE_SEND_INTERNAL_COPY="false"
INVOICE_INTERNAL_COPY_EMAIL=""

# =============================================================================
# CUSTOM FIELDS (Optional)
# =============================================================================

# Add custom company fields
INVOICE_COMPANY_WEBSITE=""
INVOICE_COMPANY_REGISTRATION_NUMBER=""

# Custom payment terms text
INVOICE_CUSTOM_PAYMENT_TERMS=""

# Custom footer text
INVOICE_CUSTOM_FOOTER=""

# =============================================================================
# NOTES
# =============================================================================

# Configuration Notes:
# - All currency amounts should be in decimal format
# - Tax rates in decimal format (0.08 = 8%)
# - Use absolute paths for file paths
# - Store sensitive credentials (API keys, passwords) in secure vault
# - Test configuration in development environment first
# - Review settings with accounting team before production use
