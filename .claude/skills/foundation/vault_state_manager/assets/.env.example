# Vault State Manager - Environment Configuration Example
# Copy to .env and fill in actual values (NEVER commit .env to git)

# ============================================================================
# REQUIRED: Vault Connection
# ============================================================================

# Vault server address (required)
VAULT_ADDR=https://vault.example.com

# Vault authentication token (required)
# SECURITY: Source from secure location, never hardcode
# Options:
#   - Read from file: VAULT_TOKEN=$(cat /run/secrets/vault-token)
#   - From another secret manager: VAULT_TOKEN=$(aws secretsmanager get-secret-value ...)
#   - For IAM auth: Use AWS/Azure/GCP SDK auth instead
VAULT_TOKEN=<your-vault-token>

# ============================================================================
# OPTIONAL: Vault Enterprise
# ============================================================================

# Namespace (Vault Enterprise only)
# VAULT_NAMESPACE=my-team

# ============================================================================
# OPTIONAL: Operational Configuration
# ============================================================================

# Operation timeout in seconds (default: 30)
# VAULT_OPERATION_TIMEOUT=30

# Maximum retry attempts (default: 3)
# VAULT_MAX_RETRIES=3

# Audit log file path (default: stderr)
# VAULT_AUDIT_LOG_PATH=./logs/vault-audit.log

# Cache TTL in seconds (default: 300 = 5 minutes)
# VAULT_CACHE_TTL=300

# ============================================================================
# DEVELOPMENT ONLY: DO NOT USE IN PRODUCTION
# ============================================================================

# Enable development mode (skip some validations)
# WARNING: Only use in local development
# VAULT_DEV_MODE=false

# Skip TLS certificate verification
# WARNING: Only use in development with self-signed certs
# VAULT_SKIP_VERIFY=false

# ============================================================================
# ALTERNATIVE: AWS Secrets Manager
# ============================================================================

# AWS region
# AWS_REGION=us-east-1

# AWS credentials (prefer IAM roles instead)
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>

# ============================================================================
# ALTERNATIVE: Azure Key Vault
# ============================================================================

# Azure tenant ID
# AZURE_TENANT_ID=<tenant-id>

# Azure client ID
# AZURE_CLIENT_ID=<client-id>

# Azure client secret (prefer managed identity instead)
# AZURE_CLIENT_SECRET=<client-secret>

# Azure Key Vault name
# AZURE_VAULT_NAME=<vault-name>

# ============================================================================
# ALTERNATIVE: GCP Secret Manager
# ============================================================================

# GCP project ID
# GCP_PROJECT_ID=<project-id>

# Path to service account key (prefer workload identity instead)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application environment (determines vault path prefix)
APP_ENV=development

# Application name (used in vault paths)
APP_NAME=myapp

# ============================================================================
# PROXY CONFIGURATION (if behind corporate proxy)
# ============================================================================

# HTTP proxy
# HTTP_PROXY=http://proxy.corp.com:8080

# HTTPS proxy
# HTTPS_PROXY=http://proxy.corp.com:8080

# No proxy exceptions
# NO_PROXY=localhost,127.0.0.1,.corp.com

# ============================================================================
# NOTES
# ============================================================================
#
# 1. NEVER commit .env files to version control
#    - Add .env to .gitignore immediately
#    - Only commit .env.example with placeholder values
#
# 2. Prefer managed identities over static credentials
#    - AWS: Use IAM roles for EC2/ECS/Lambda
#    - Azure: Use Managed Identity
#    - GCP: Use Workload Identity
#
# 3. Rotate credentials regularly
#    - Tokens should have limited TTL (< 24 hours)
#    - Implement automatic renewal
#    - Document rotation procedures
#
# 4. Environment-specific configuration
#    - Use separate .env files per environment
#    - Example: .env.development, .env.staging, .env.production
#    - Load appropriate file based on APP_ENV
#
# 5. Validation
#    - Application should fail fast if required variables missing
#    - Log validation errors clearly (without exposing values)
#    - Document all required variables
#
# ============================================================================
