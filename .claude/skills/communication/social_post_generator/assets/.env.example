# Social Post Generator - Environment Variables Example
# Copy this file to .env and customize for your environment

# ============================================
# REQUIRED SETTINGS
# ============================================

# Vault path (absolute path to vault directory)
VAULT_PATH="/absolute/path/to/vault"

# Social posts storage location (auto-created if missing)
SOCIAL_POSTS_PATH="${VAULT_PATH}/Social_Posts"

# Brand configuration (REQUIRED)
SOCIAL_BRAND_NAME="Your Company Name"
SOCIAL_BRAND_VOICE="professional"          # professional | conversational | playful | authoritative
SOCIAL_TARGET_AUDIENCE="B2B decision makers"

# ============================================
# PLATFORM CONFIGURATION
# ============================================

# Default platforms (comma-separated)
SOCIAL_DEFAULT_PLATFORMS="linkedin,twitter"

# Enable/disable specific platforms
SOCIAL_LINKEDIN_ENABLED="true"
SOCIAL_TWITTER_ENABLED="true"
SOCIAL_FACEBOOK_ENABLED="true"
SOCIAL_INSTAGRAM_ENABLED="false"

# ============================================
# CONTENT CONFIGURATION
# ============================================

# Default tone
SOCIAL_DEFAULT_TONE="professional"         # professional | casual | enthusiastic | informative

# Hashtag limits per platform
SOCIAL_MAX_HASHTAGS_LINKEDIN="5"
SOCIAL_MAX_HASHTAGS_TWITTER="3"
SOCIAL_MAX_HASHTAGS_FACEBOOK="3"

# Emoji usage
SOCIAL_INCLUDE_EMOJI="true"
SOCIAL_EMOJI_STYLE="moderate"              # minimal | moderate | enthusiastic

# Character optimization
SOCIAL_LINKEDIN_OPTIMAL_LENGTH="1500"      # Chars (max 3000)
SOCIAL_TWITTER_MAX_LENGTH="280"            # Chars (enforced)
SOCIAL_FACEBOOK_OPTIMAL_LENGTH="600"       # Chars (max 63206)

# ============================================
# A/B TESTING
# ============================================

# A/B testing configuration
SOCIAL_AB_VARIATIONS_COUNT="3"             # Number of variations per platform
SOCIAL_AB_DEFAULT_VARIABLES="headline,cta_text,emoji_usage"

# ============================================
# CTA CONFIGURATION
# ============================================

# Default CTA settings
SOCIAL_DEFAULT_CTA_TYPE="learn_more"       # learn_more | sign_up | download | register | contact
SOCIAL_CTA_URL_BASE="https://yourcompany.com"

# UTM tracking
SOCIAL_UTM_SOURCE_AUTO="true"              # Auto-add utm_source based on platform
SOCIAL_UTM_MEDIUM="social"
SOCIAL_UTM_CAMPAIGN=""                     # Set per campaign

# ============================================
# HASHTAG STRATEGY
# ============================================

# Branded hashtags (comma-separated)
SOCIAL_BRANDED_HASHTAGS="#YourBrand,#YourProduct"

# Auto-generate industry hashtags
SOCIAL_AUTO_HASHTAGS="true"

# Trending hashtags monitoring
SOCIAL_INCLUDE_TRENDING="false"

# ============================================
# COMPLIANCE & APPROVAL
# ============================================

# Require approval before posting
SOCIAL_REQUIRE_APPROVAL="false"

# Topics requiring approval (comma-separated)
SOCIAL_APPROVAL_TOPICS="executive_announcement,financial_disclosure,crisis_response"

# Legal disclaimer
SOCIAL_INCLUDE_DISCLAIMER="false"
SOCIAL_DISCLAIMER_TEXT=""

# Competitor mention detection
SOCIAL_FLAG_COMPETITOR_MENTIONS="true"
SOCIAL_COMPETITORS="CompetitorA,CompetitorB"

# ============================================
# SCHEDULING & TIMING
# ============================================

# Best posting times (platform-specific)
SOCIAL_LINKEDIN_BEST_TIMES="tue-thu:07-09,12-13"  # Days:Hours (24h format)
SOCIAL_TWITTER_BEST_TIMES="mon-fri:08-10,18-21"
SOCIAL_FACEBOOK_BEST_TIMES="wed-fri:13-15"

# Timezone for scheduling
SOCIAL_DEFAULT_TIMEZONE="America/New_York"

# ============================================
# VISUAL ASSETS
# ============================================

# Visual asset recommendations
SOCIAL_RECOMMEND_VISUALS="true"
SOCIAL_IMAGE_TEMPLATES_PATH="${VAULT_PATH}/Social_Templates/Images"

# Required image dimensions
SOCIAL_LINKEDIN_IMAGE_SIZE="1200x627"
SOCIAL_TWITTER_IMAGE_SIZE="1200x675"
SOCIAL_FACEBOOK_IMAGE_SIZE="1200x630"

# ============================================
# AUDIT & LOGGING
# ============================================

# Audit log path
SOCIAL_AUDIT_LOG_PATH="${VAULT_PATH}/Audit_Logs"

# Current agent session ID (set by agent runtime)
SOCIAL_SESSION_ID=""

# Log post creation events
SOCIAL_LOG_POSTS="true"

# Log level
SOCIAL_LOG_LEVEL="info"                    # error | warn | info | debug

# ============================================
# ANALYTICS & TRACKING
# ============================================

# Analytics integration
SOCIAL_ANALYTICS_ENABLED="false"
SOCIAL_ANALYTICS_PLATFORM="google_analytics"  # google_analytics | mixpanel | amplitude

# Track engagement metrics
SOCIAL_TRACK_ENGAGEMENT="false"

# Success metrics thresholds
SOCIAL_SUCCESS_CTR_MIN="2.0"               # % click-through rate
SOCIAL_SUCCESS_ENGAGEMENT_MIN="1.5"         # % engagement rate

# ============================================
# CONTENT MODERATION
# ============================================

# Content moderation
SOCIAL_ENABLE_MODERATION="false"
SOCIAL_FLAG_SENSITIVE_TERMS="true"
SOCIAL_SENSITIVE_TERMS="confidential,internal,proprietary"

# Link validation
SOCIAL_VALIDATE_LINKS="true"
SOCIAL_ALLOWED_DOMAINS="yourcompany.com,blog.yourcompany.com"

# ============================================
# PERFORMANCE & STORAGE
# ============================================

# Auto-archive posts older than N days
SOCIAL_AUTO_ARCHIVE_DAYS="90"
SOCIAL_ARCHIVE_PATH="${VAULT_PATH}/Social_Posts_Archive"

# Maximum posts to retain
SOCIAL_MAX_POSTS="1000"                    # 0 = unlimited

# Disk usage alert threshold
SOCIAL_DISK_USAGE_ALERT_THRESHOLD="80"     # percentage

# ============================================
# INTEGRATION
# ============================================

# Enable integration with company_handbook_enforcer
SOCIAL_ENABLE_COMPLIANCE_CHECK="false"

# Enable integration with approval_request_creator
SOCIAL_ENABLE_APPROVAL_WORKFLOW="false"

# Enable integration with vault_state_manager
SOCIAL_ENABLE_VAULT_INTEGRATION="true"

# ============================================
# FEATURE FLAGS
# ============================================

# Enable batch post generation
SOCIAL_ENABLE_BATCH_MODE="true"

# Enable post scheduling
SOCIAL_ENABLE_SCHEDULING="false"

# Enable visual asset generation
SOCIAL_ENABLE_VISUAL_GEN="false"

# Enable sentiment analysis
SOCIAL_ENABLE_SENTIMENT_ANALYSIS="false"

# ============================================
# TESTING & DEVELOPMENT
# ============================================

# Enable debug mode
SOCIAL_DEBUG="false"

# Dry run mode (create drafts but don't save)
SOCIAL_DRY_RUN="false"

# Test mode
SOCIAL_TEST_MODE="false"
