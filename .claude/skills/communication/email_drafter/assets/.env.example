# Email Drafter - Environment Variables Example
# Copy this file to .env and customize for your environment

# ============================================
# REQUIRED SETTINGS
# ============================================

# Vault path (absolute path to vault directory)
VAULT_PATH="/absolute/path/to/vault"

# Email drafts storage location (auto-created if missing)
EMAIL_DRAFTS_PATH="${VAULT_PATH}/Email_Drafts"

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# Default tone for emails when not specified
# Options: formal | semi-formal | friendly
EMAIL_DEFAULT_TONE="formal"

# Email signature configuration
EMAIL_SIGNATURE_NAME="AI Assistant"
EMAIL_SIGNATURE_TITLE="Automation System"
EMAIL_SIGNATURE_COMPANY="Your Company Name"
EMAIL_SIGNATURE_CONTACT="support@yourcompany.com"

# ============================================
# TEMPLATES (Optional)
# ============================================

# Custom email templates location
EMAIL_TEMPLATE_PATH="${VAULT_PATH}/Email_Templates"

# Auto-generate subject line if not provided
EMAIL_AUTO_SUBJECT="true"

# Include follow-up action suggestions
EMAIL_INCLUDE_FOLLOWUP="true"

# Maximum subject line length (characters)
EMAIL_MAX_SUBJECT_LENGTH=80

# ============================================
# COMPLIANCE (Optional)
# ============================================

# Require human review for all drafts
EMAIL_REQUIRE_REVIEW="false"

# Add confidentiality notice to emails
EMAIL_CONFIDENTIALITY_NOTICE="true"

# Confidentiality notice text
EMAIL_DISCLAIMER_TEXT="This email and any attachments are confidential and intended solely for the addressee. If you are not the intended recipient, please delete this email and notify the sender immediately."

# ============================================
# AUDIT & LOGGING (Optional)
# ============================================

# Audit log path for email draft tracking
EMAIL_AUDIT_LOG_PATH="${VAULT_PATH}/Audit_Logs"

# Current agent session ID (set by agent runtime)
EMAIL_SESSION_ID=""

# Log draft creation events
EMAIL_LOG_DRAFTS="true"

# Log level (error | warn | info | debug)
EMAIL_LOG_LEVEL="info"

# ============================================
# CONTENT GENERATION (Optional)
# ============================================

# Maximum email body length (characters)
EMAIL_MAX_BODY_LENGTH=5000

# Include alternative subject lines
EMAIL_INCLUDE_ALT_SUBJECTS="true"

# Number of alternative subjects to generate
EMAIL_ALT_SUBJECTS_COUNT=3

# Include tone analysis section
EMAIL_INCLUDE_TONE_ANALYSIS="true"

# Include content checklist
EMAIL_INCLUDE_CONTENT_CHECKLIST="true"

# ============================================
# RECIPIENT TYPES (Reference)
# ============================================

# These are not environment variables, but reference values for recipient.type field
# - customer: End users, paying customers
# - vendor: Suppliers, service providers
# - partner: Strategic partners, resellers
# - internal_team: Company employees, team members
# - executive: C-level, directors, senior leadership
# - external_stakeholder: Investors, board members, advisors
# - support_request: People requesting help/support

# ============================================
# EMAIL TYPES (Reference)
# ============================================

# These are not environment variables, but reference values for intent field
# - customer_inquiry_response: Answering customer questions
# - meeting_request: Scheduling meetings
# - status_update: Project/task progress
# - polite_rejection: Declining requests
# - escalation_response: Addressing complaints
# - approval_request: Seeking authorization
# - follow_up: Checking in after meeting/email
# - introduction: Introducing team/product
# - thank_you: Expressing gratitude
# - apology: Addressing mistakes/issues
# - negotiation: Vendor/partner negotiations
# - onboarding: New customer welcome

# ============================================
# PERFORMANCE TUNING (Optional)
# ============================================

# Maximum concurrent draft generation operations
EMAIL_MAX_CONCURRENT_DRAFTS=10

# Draft generation timeout (milliseconds)
EMAIL_GENERATION_TIMEOUT=10000

# Enable draft caching (for similar requests)
EMAIL_ENABLE_CACHING="false"

# Cache TTL (seconds)
EMAIL_CACHE_TTL=3600

# ============================================
# STORAGE MANAGEMENT (Optional)
# ============================================

# Auto-archive drafts older than N days
EMAIL_AUTO_ARCHIVE_DAYS=90

# Archive location
EMAIL_ARCHIVE_PATH="${VAULT_PATH}/Email_Drafts_Archive"

# Maximum drafts to retain (0 = unlimited)
EMAIL_MAX_DRAFTS=0

# Alert if disk usage exceeds threshold (percentage)
EMAIL_DISK_USAGE_ALERT_THRESHOLD=80

# ============================================
# SECURITY (Optional)
# ============================================

# Sanitize customer names/emails in logs
EMAIL_SANITIZE_LOGS="true"

# Validate recipient email format
EMAIL_VALIDATE_RECIPIENTS="true"

# Prevent path traversal attacks
EMAIL_VALIDATE_PATHS="true"

# Require HTTPS for links in emails
EMAIL_REQUIRE_HTTPS_LINKS="false"

# ============================================
# INTEGRATION (Optional)
# ============================================

# Enable integration with company_handbook_enforcer
EMAIL_ENABLE_COMPLIANCE_CHECK="false"

# Enable integration with approval_request_creator
EMAIL_ENABLE_APPROVAL_WORKFLOW="false"

# Approval required for external stakeholder emails
EMAIL_REQUIRE_APPROVAL_FOR_EXTERNAL="true"

# Enable integration with vault_state_manager
EMAIL_ENABLE_VAULT_INTEGRATION="true"

# ============================================
# FEATURE FLAGS (Optional)
# ============================================

# Enable batch email draft generation
EMAIL_ENABLE_BATCH_MODE="true"

# Enable email threading preservation (Re:, Fwd:)
EMAIL_ENABLE_THREADING="true"

# Enable timezone handling for meeting requests
EMAIL_ENABLE_TIMEZONE_HANDLING="true"

# Enable action item ownership tracking
EMAIL_ENABLE_ACTION_TRACKING="true"

# Enable draft versioning
EMAIL_ENABLE_VERSIONING="false"

# ============================================
# LOCALIZATION (Optional)
# ============================================

# Default language for email drafts
EMAIL_DEFAULT_LANGUAGE="en"

# Date format (ISO 8601 recommended)
EMAIL_DATE_FORMAT="YYYY-MM-DD"

# Time format (24-hour recommended)
EMAIL_TIME_FORMAT="HH:mm"

# Timezone for date/time display
EMAIL_DEFAULT_TIMEZONE="UTC"

# ============================================
# NOTIFICATIONS (Optional)
# ============================================

# Note: email_drafter does NOT send emails, only creates drafts
# These settings are for notifying when drafts are created

# Notify on draft creation (requires external service)
EMAIL_NOTIFY_ON_DRAFT="false"

# Notification webhook URL
EMAIL_NOTIFICATION_WEBHOOK=""

# ============================================
# TESTING & DEVELOPMENT (Optional)
# ============================================

# Enable debug mode (verbose logging)
EMAIL_DEBUG="false"

# Dry run mode (create drafts but don't write to disk)
EMAIL_DRY_RUN="false"

# Test mode (use test data instead of real data)
EMAIL_TEST_MODE="false"

# Mock recipient for testing
EMAIL_TEST_RECIPIENT="test@example.com"
