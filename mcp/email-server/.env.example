# ─────────────────────────────────────────────
# Email MCP Server — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Gmail OAuth2 credentials ─────────────────
# Obtain from Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client IDs
GMAIL_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here

# Obtain refresh token via one-time consent flow (see EMAIL_MCP_SERVER.md § Setup)
# Required scopes: gmail.send, gmail.compose, gmail.readonly, gmail.modify
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# ── Sender identity ───────────────────────────
# The authenticated Gmail account. Usually "me" (resolves to the authed user).
GMAIL_USER=me

# ── Behaviour flags ───────────────────────────
# DRY_RUN=true  → tools respond with previews, no real API calls are made
# Recommended for initial testing
DRY_RUN=true

# REQUIRE_APPROVAL=true → send_email and schedule_email require "approved: true" parameter
# Enable for production to prevent accidental sends
REQUIRE_APPROVAL=true

# ── Rate limiting ─────────────────────────────
# Maximum number of emails that can be sent per day (resets at midnight UTC)
# Protects against accidental mass-mailing
EMAIL_RATE_LIMIT_DAILY=10

# ── Logging ───────────────────────────────────
# debug | info | error
# debug: Log all tool calls with arguments
# info:  Log successful operations (recommended)
# error: Log only errors
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Notes:
# - Logs are written to logs/email-server-YYYY-MM-DD.json (NDJSON format)
# - Rate limit state persisted to rate_limit.json
# - Scheduled emails stored in schedules.json
# ─────────────────────────────────────────────
