{
  "mcpServers": {
    "ai-employee-email": {
      "command": "node",
      "args": ["mcp/email-server/src/index.js"],
      "env": {
        "GMAIL_CLIENT_ID": "${GMAIL_CLIENT_ID}",
        "GMAIL_CLIENT_SECRET": "${GMAIL_CLIENT_SECRET}",
        "GMAIL_REFRESH_TOKEN": "${GMAIL_REFRESH_TOKEN}",
        "GMAIL_USER": "me",
        "DRY_RUN": "false",
        "REQUIRE_APPROVAL": "true",
        "EMAIL_RATE_LIMIT_DAILY": "10",
        "LOG_LEVEL": "info"
      }
    }
  }
}
