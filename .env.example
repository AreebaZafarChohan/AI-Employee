# AI Employee Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# API Keys
# ─────────────────────────────────────────────

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL (used by Python watchers to post activity logs)
BACKEND_API_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────
# LinkedIn Watcher (Silver Tier)
# ─────────────────────────────────────────────

# LinkedIn Credentials
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password

# LinkedIn Watch Settings
LINKEDIN_WATCH_INTERVAL=300

# ─────────────────────────────────────────────
# Gmail Watcher (Silver Tier)
# ─────────────────────────────────────────────

# Gmail OAuth2 credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_USER=me

# ─────────────────────────────────────────────
# Vault Configuration
# ─────────────────────────────────────────────

VAULT_PATH=./AI-Employee-Vault

# ─────────────────────────────────────────────
# File Watcher Configuration
# ─────────────────────────────────────────────

WATCH_PATH=/path/to/watch/directory
WATCH_RECURSIVE=false
WATCH_PATTERNS=*.md,*.txt

# ─────────────────────────────────────────────
# Processing Configuration
# ─────────────────────────────────────────────

MAX_PROCESSING_TIME=30
RETRY_ATTEMPTS=3
RETENTION_DAYS=90

# ─────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────

# Set to "true" to test without real actions
DRY_RUN=false

# WhatsApp auto-reply (set to false so drafts go to pending approval)
WA_AUTO_REPLY=false

# WhatsApp Web watcher (set to "true" to run WhatsApp scraper in backend)
WA_WATCHER_ENABLED=true

# WhatsApp profile directory (persistent browser session)
WA_PROFILE_DIR=.whatsapp_profile

# WhatsApp headless mode (set to "true" for no browser UI)
WA_HEADLESS=false

# ─────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────

LOG_LEVEL=INFO
LOG_DIR=logs

# ─────────────────────────────────────────────
# Gold Tier - Database
# ─────────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/gold_tier
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Gold Tier - JWT Authentication
# ─────────────────────────────────────────────

JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─────────────────────────────────────────────
# AI Sales Agent
# ─────────────────────────────────────────────

# Grok API (fallback AI provider)
GROK_API_KEY=your_grok_api_key_here

# Sales Agent Settings
SALES_TARGET_KEYWORDS=AI,SaaS,automation
SALES_TARGET_INDUSTRIES=technology,finance,healthcare
CALENDLY_LINK=https://calendly.com/your-link
